{
  "name": "rafaelleme/payment-gateways",
  "description": "Framework-agnostic payment gateway abstraction with support for multiple providers.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Rafaelleme\\PaymentGateways\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Rafaelleme\\PaymentGateways\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94"
  },
  "suggest": {
    "illuminate/support": "Required for Laravel integration (ServiceProvider and Facade)."
  },
  "extra": {
    "laravel": {
      "providers": [
        "Rafaelleme\\PaymentGateways\\Laravel\\PaymentGatewaysServiceProvider"
      ],
      "aliases": {
        "PaymentGateway": "Rafaelleme\\PaymentGateways\\Laravel\\Facades\\PaymentGateway"
      }
    }
  }
}
